{
    "name": "playroom/livewire-adapter",
    "description": "Livewire adapter package for PlayRoom built on the Alpine adapter",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "laravel/framework": "^13.0",
        "livewire/livewire": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "PlayRoom\\LivewirePlayRoom\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "PlayRoom\\LivewirePlayRoom\\LivewirePlayRoomServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
